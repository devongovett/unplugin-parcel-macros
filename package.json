{
  "name": "unplugin-parcel-macros",
  "version": "0.2.0",
  "main": "unplugin-macros.js",
  "types": "unplugin-macros.d.ts",
  "imports": {
    "#native": {
      "node-addons": "./index.js",
      "default": "./wasm.mjs"
    },
    "#source-map": {
      "node-addons": "@parcel/source-map",
      "default": "@parcel/source-map/dist/wasm.js"
    }
  },
  "napi": {
    "name": "unplugin-parcel-macros",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devongovett/unplugin-parcel-macros"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cargo build --target wasm32-unknown-unknown --release && wasm-opt target/wasm32-unknown-unknown/release/unplugin_parcel_macros.wasm --all-features --asyncify --pass-arg=asyncify-imports@env.await_promise_sync --pass-arg=asyncify-stack-size@65536 -Oz -o unplugin-parcel-macros.wasm",
    "prepublishOnly": "napi prepublish -t npm",
    "universal": "napi universal",
    "version": "napi version"
  },
  "packageManager": "yarn@4.1.0",
  "dependencies": {
    "@parcel/source-map": "^2.1.1",
    "@swc/core": "^1.15.3",
    "napi-wasm": "^1.0.1",
    "unplugin": "^1.9.0"
  }
}
